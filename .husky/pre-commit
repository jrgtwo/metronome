pnpm lint

# Regenerate the paint-shell skeleton from the real app when layout-affecting files
# change, so skeleton.html never drifts. `pnpm snapshot` auto-installs the headless
# Chromium shell on first run (one-time ~download), then renders the build (~5-8s).
# Skip a commit with `--no-verify` if needed.
if git diff --cached --name-only | grep -qE '^(src/|index\.html$)'; then
  echo "Layout files changed — regenerating skeleton.html…"
  pnpm snapshot && git add skeleton.html
fi
